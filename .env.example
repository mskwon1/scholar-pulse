# [Required for AI Analysis] Google Gemini API Key
# 발급처: Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# [Optional but Recommended] Semantic Scholar API Key
# 없어도 폴백(Fallback) 통신으로 동작하지만 트래픽 리밋이 매우 작습니다.
S2_API_KEY=

# [Required for State Management] Supabase Database
# 기발송 논문 중복 방지 저장 및 유저 설정을 위해 사용
SUPABASE_PROJECT_ID=your_supabase_project_id_here
# 프론트엔드 연동용 공개 키 (Publishable key)
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
# 백엔드 에이전트 전용 비밀 키 (Secret API key)
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# [Required for Delivery] Resend Email API Key
# 완성된 리포트를 이메일로 전송하기 위해 사용
RESEND_API_KEY=your_resend_api_key_here

# [Optional but Recommended] Resend 발신용 이메일 주소
# 커스텀 도메인(Verified Domain)이 연결된 이메일 계정을 입력하세요 (안 그러면 스팸으로 필터링되거나 Resend Sandbox 정책에 의해 발송이 차단됨)
# 미입력 시 'onboarding@resend.dev'를 기본으로 사용하여 Sandbox 메일 주소(본인)로만 전송 가능
RESEND_FROM_EMAIL=

# [Required for Delivery] Recipient Email Address
# 리포트를 받아볼 이메일 주소
DELIVERY_EMAIL=your_email@example.com
